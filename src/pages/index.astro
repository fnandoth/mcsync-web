---
import BaseLayout from "../layouts/BaseLayout.astro";
import LanguageToggle from "../components/LanguageToggle.astro";
---

<BaseLayout title="MCSync · Landing">
  <header class="site-header">
    <div class="shell site-nav">
      <div class="brand">MCSync</div>
      <nav class="nav-links" aria-label="Navegación principal">
        <a href="#el-problema" data-i18n="nav.problem">El problema</a>
        <a href="#como-funciona" data-i18n="nav.howWorks">Cómo funciona</a>
        <a href="#la-app" data-i18n="nav.app">La app</a>
        <a href="#requisitos" data-i18n="nav.requirements">Requisitos</a>
        <a href="#configurar" data-i18n="nav.setup">Configurar</a>
        <a href="#ser-host" data-i18n="nav.beHost">Ser host</a>
        <a href="#descargar" data-i18n="nav.download">Descargar</a>
      </nav>
      <LanguageToggle />
    </div>
  </header>

  <main>
    <section id="hero">
      <div class="shell">
        <h1 class="display" data-i18n="hero.title">MCSync</h1>
        <p class="section-subtitle" data-i18n="hero.subtitle">
          El servidor de Minecraft siempre disponible. Sin importar quién
          hostea.
        </p>
        <p class="lead" data-i18n="hero.description">
          MCSync es una app de escritorio para Windows que automatiza la
          rotación del host en servidores Minecraft entre amigos. Con un clic,
          comprime el mundo, lo sube a GitHub, lo descarga, descomprime y lanza
          el servidor.
        </p>
        <div class="cta-row">
          <a
            class="btn btn-primary"
            href="https://github.com/fnandoth/MCSync/releases/latest"
            target="_blank"
            rel="noopener noreferrer"
            data-i18n="hero.download"
            >Descargar</a
          >
          <a
            class="btn btn-secondary"
            href="https://github.com/fnandoth/MCSync"
            target="_blank"
            rel="noopener noreferrer"
            data-i18n="hero.github"
            >Ver en GitHub</a
          >
        </div>
        <p class="meta" data-i18n="hero.meta">Windows · .NET 8 · Open Source · v0.2.0</p>
      </div>
    </section>

    <section id="el-problema">
      <div class="shell">
        <h2 class="section-title" data-i18n="problem.title">El problema</h2>
        <p class="lead" data-i18n="problem.description">
          Cuando el amigo que hostea se desconecta, todos pierden acceso al
          mundo. El flujo manual de comprimir ZIP, enviar, descomprimir y volver
          a configurar el servidor es lento; MCSync lo automatiza de punta a
          punta.
        </p>
        <div class="split">
          <article class="panel">
            <h3 data-i18n="problem.withoutTitle">Sin MCSync</h3>
            <ul class="mono-list">
              <li data-i18n="problem.without.1">— Detener servidor y buscar la carpeta del mundo</li>
              <li data-i18n="problem.without.2">— Comprimir todo en un ZIP</li>
              <li data-i18n="problem.without.3">— Enviar archivo manualmente</li>
              <li data-i18n="problem.without.4">— Descargar y descomprimir en otra PC</li>
              <li data-i18n="problem.without.5">— Reconfigurar server.jar y túnel</li>
            </ul>
          </article>
          <article class="panel">
            <h3 data-i18n="problem.withTitle">Con MCSync</h3>
            <ul class="mono-list">
              <li data-i18n="problem.with.1">✓ Presionar <code>STOP HOST AND SYNC</code></li>
              <li data-i18n="problem.with.2">✓ Presionar <code>START HOST</code> en la otra PC</li>
              <li data-i18n="problem.with.3">✓ Seguir jugando en el mismo mundo</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section id="como-funciona">
      <div class="shell">
        <h2 class="section-title" data-i18n="howWorks.title">Cómo funciona</h2>
        <div class="stepper">
          <article class="step-group">
            <h3 data-i18n="howWorks.stopTitle">Al dejar de hostear:</h3>
            <ol class="steps">
              <li data-step="1" data-i18n="howWorks.stop.1">Presionas <code>STOP HOST AND SYNC</code></li>
              <li data-step="2" data-i18n="howWorks.stop.2">El servidor se detiene limpiamente</li>
              <li data-step="3" data-i18n="howWorks.stop.3">
                El mundo se comprime y sube a tu repo privado de GitHub
              </li>
              <li data-step="4" data-i18n="howWorks.stop.4">Se libera el turno</li>
            </ol>
          </article>
          <article class="step-group">
            <h3 data-i18n="howWorks.startTitle">Al querer hostear:</h3>
            <ol class="steps">
              <li data-step="1" data-i18n="howWorks.start.1">Presionas <code>START HOST</code></li>
              <li data-step="2" data-i18n="howWorks.start.2">
                MCSync descarga el mundo más reciente desde GitHub
              </li>
              <li data-step="3" data-i18n="howWorks.start.3">Lo descomprime y prepara el servidor</li>
              <li data-step="4" data-i18n="howWorks.start.4">
                Inicia <code>server.jar</code> y el túnel de <code>playit.gg</code>
              </li>
              <li data-step="5" data-i18n="howWorks.start.5">
                Obtienes el link para compartir con tus amigos
              </li>
            </ol>
          </article>
        </div>
      </div>
    </section>

    <section id="la-app">
      <div class="shell">
        <h2 class="section-title" data-i18n="app.title">La app</h2>
        <p class="section-subtitle" data-i18n="app.subtitle">Interfaz directa. Sin distracciones.</p>
        <div class="shots">
          <div class="shot">
            <img
              class="shot-image"
              src="/screenshots/dashboard.png"
              alt="Dashboard principal de MCSync mostrando el estado del servidor y los botones de acción"
              loading="lazy"
              decoding="async"
            />
          </div>
          <p class="shot-note" data-i18n="app.dashboard">
            Dashboard principal con estado del servidor y botones de acción
          </p>
          <div class="shot">
            <img
              class="shot-image"
              src="/screenshots/config.png"
              alt="Panel de configuración de MCSync con campos para GitHub Owner, Repo, Branch, Token, Server Jar path y Playit.gg URL"
              loading="lazy"
              decoding="async"
            />
          </div>
          <p class="shot-note" data-i18n="app.config">
            Los campos de configuración: GitHub Owner, Repo, Branch, Token,
            Server Jar path y Playit.gg URL
          </p>
          <div class="shot">
            <img
              class="shot-image"
              src="/screenshots/dashboardSync.png"
              alt="Dashboard de MCSync mostrando el proceso de sincronización en curso, con mensajes de estado y barra de progreso"
              loading="lazy"
              decoding="async"
            />
          </div>
          <p class="shot-note" data-i18n="app.sync">
            Dashboard mostrando el proceso de sincronización en curso, con mensajes de estado
          </p>
        </div>
      </div>
    </section>

    <section id="requisitos">
      <div class="shell">
        <h2 class="section-title" data-i18n="requirements.title">Requisitos</h2>
        <p class="section-subtitle" data-i18n="requirements.subtitle">Configura esto una sola vez</p>
        <ol class="requirements">
          <li>
            <strong data-i18n="requirements.java">Java 21 o superior</strong>
            <p data-i18n="requirements.javaDesc">
              Debe estar instalado y agregado al PATH del sistema. Descárgalo
              desde <a href="https://adoptium.net/" target="_blank" rel="noopener noreferrer">adoptium.net</a>
              o el JDK oficial de
              <a href="https://www.oracle.com/java/technologies/downloads/" target="_blank" rel="noopener noreferrer">Oracle</a>.
            </p>
          </li>
          <li>
            <strong data-i18n="requirements.playit">playit.gg</strong>
            <p data-i18n="requirements.playitDesc">
              Descarga e instala el <code>.msi</code> desde
              <a href="https://playit.gg/download/windows" target="_blank" rel="noopener noreferrer"
                >playit.gg/download/windows</a
              >. La primera vez que lo abras deberás crear una cuenta, confirmar
              el agente y configurarlo para Minecraft Java Edition. Este proceso
              toma menos de 2 minutos. Al finalizar, playit.gg te entregará un
              link — guárdalo. Si lo pierdes, puedes recuperarlo ejecutando
              <code>playit</code> en una terminal.
            </p>
          </li>
          <li>
            <strong data-i18n="requirements.repo">Repositorio privado en GitHub</strong>
            <p data-i18n="requirements.repoDesc">
              Crea un repositorio nuevo (preferiblemente privado) en
              <a href="https://github.com/new" target="_blank" rel="noopener noreferrer">GitHub</a>. Este repo
              almacenará el mundo y el estado de sincronización. No necesitas
              subir nada manualmente.
            </p>
          </li>
          <li>
            <strong data-i18n="requirements.token">Token de GitHub (Fine-grained)</strong>
            <p data-i18n="requirements.tokenDesc">
              Accede a
              <a
                href="https://github.com/settings/personal-access-tokens"
                target="_blank"
                rel="noopener noreferrer"
                >github.com/settings/personal-access-tokens</a
              >. Al crear el token: ponle cualquier nombre, en
              <code>Repository Access</code> selecciona
              <code>Only select repositories</code> y elige el repo que creaste.
              En permisos, selecciona <code>Contents</code> y cambia el acceso a
              <code>Read and Write</code>. Genera el token y cópialo
              inmediatamente — no podrás verlo de nuevo. Si lo pierdes en el
              futuro, puedes generar uno nuevo sin perder el mundo.
            </p>
          </li>
          <li>
            <strong data-i18n="requirements.jar">server.jar de Minecraft</strong>
            <p data-i18n="requirements.jarDesc">
              Descárgalo desde
              <a href="https://www.minecraft.net/en-us/download/server" target="_blank" rel="noopener noreferrer"
                >minecraft.net/en-us/download/server</a
              >
              para la versión más reciente. Para versiones específicas usa
              <a href="https://mcversions.net/" target="_blank" rel="noopener noreferrer">mcversions.net</a>.
            </p>
          </li>
        </ol>
      </div>
    </section>

    <section id="configurar">
      <div class="shell">
        <h2 class="section-title" data-i18n="setup.title">Configurar MCSync</h2>
        <p class="section-subtitle" data-i18n="setup.subtitle">
          Solo la primera vez. Los demás usuarios comparten la misma
          configuración de GitHub.
        </p>
        <div class="terminal-table">
          <table>
            <thead>
              <tr>
                <th data-i18n="setup.field">Campo</th>
                <th data-i18n="setup.example">Ejemplo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td data-i18n="setup.owner">GitHub Owner</td>
                <td><code>steve</code></td>
              </tr>
              <tr>
                <td data-i18n="setup.repo">GitHub Repo</td>
                <td><code>server</code></td>
              </tr>
              <tr>
                <td data-i18n="setup.branch">GitHub Branch</td>
                <td><code>main</code></td>
              </tr>
              <tr>
                <td data-i18n="setup.token">GitHub Token</td>
                <td><code>github_pat_...</code></td>
              </tr>
              <tr>
                <td data-i18n="setup.jar">Server Jar</td>
                <td><code>C:\minecraft\server.jar</code></td>
              </tr>
              <tr>
                <td data-i18n="setup.playitUrl">Playit.gg URL</td>
                <td><code>el link que te entregó playit.gg</code></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="shot">
          <img
            class="shot-image"
            src="/screenshots/configCompleted.png"
            alt="Ventana de configuración de MCSync con todos los campos completados correctamente"
            loading="lazy"
            decoding="async"
          />
        </div>

        <p class="meta" data-i18n="setup.note">
          Si pierdes el token de GitHub, puedes generar uno nuevo. El mundo no
          se pierde y no necesitas crear un nuevo repositorio.
        </p>
      </div>
    </section>

    <section id="ser-host">
      <div class="shell">
        <h2 class="section-title" data-i18n="beHost.title">¿Quieres ser host también?</h2>
        <p class="lead" data-i18n="beHost.description">
          Los amigos que quieran tomar el rol de host solo necesitan preparar su
          entorno una vez. No necesitan crear un repositorio propio ni descargar
          el mundo manualmente: MCSync lo hace automáticamente al presionar
          <code>START HOST</code>.
        </p>
        <div class="host-grid">
          <article class="host-card">
            <div class="num">01</div>
            <h3 data-i18n="beHost.step1Title">Instalar Java</h3>
            <p data-i18n="beHost.step1">Instala Java 21+ y agrégalo al PATH del sistema.</p>
          </article>
          <article class="host-card">
            <div class="num">02</div>
            <h3 data-i18n="beHost.step2Title">Configurar playit.gg</h3>
            <p data-i18n="beHost.step2">Completa el flujo inicial de 2 minutos para Minecraft Java Edition.</p>
          </article>
          <article class="host-card">
            <div class="num">03</div>
            <h3 data-i18n="beHost.step3Title">Recibir datos GitHub</h3>
            <p data-i18n="beHost.step3">Usa owner, repo, branch y token del host original.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="descargar">
      <div class="shell">
        <h2 class="section-title" data-i18n="download.title">Listo para jugar</h2>
        <p class="section-subtitle" data-i18n="download.subtitle">
          Descarga MCSync y compártelo con tus amigos.
        </p>
        <div class="cta-row">
          <a
            class="btn btn-primary"
            href="https://github.com/fnandoth/MCSync/releases/latest"
            target="_blank"
            rel="noopener noreferrer"
            data-i18n="hero.download"
            >Descargar</a
          >
          <a
            class="btn btn-secondary"
            href="https://github.com/fnandoth/MCSync"
            target="_blank"
            rel="noopener noreferrer"
            data-i18n="hero.github"
            >Ver en GitHub</a
          >
        </div>
        <p class="meta" data-i18n="download.meta">Open source · MIT License · Windows · Hecho con C# .NET 8</p>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="shell">
      <p data-i18n="footer.text">
        MCSync ·
        <a href="https://github.com/fnandoth/MCSync" target="_blank" rel="noopener noreferrer"
          >github.com/fnandoth/MCSync</a
        >
        · Open Source
      </p>
    </div>
  </footer>
</BaseLayout>
